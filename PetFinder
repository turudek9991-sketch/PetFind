-- ============================================================
-- SAVE / LOAD JSON
-- ============================================================
local function LoadConfig()
    if isfile and readfile and isfile(ConfigFile) then
        local ok, data = pcall(function() return HttpService:JSONDecode(readfile(ConfigFile)) end)
        if ok and type(data) == "table" then
            if data.AutoBuy ~= nil then Config.AutoBuy = data.AutoBuy end
            if data.AutoHop ~= nil then Config.AutoHop = data.AutoHop end
            if data.Targets and type(data.Targets) == "table" then
                for k, v in pairs(data.Targets) do
                    if Config.Targets[k] ~= nil then Config.Targets[k] = v end
                end
            end
        end
    end
end

local function SaveConfig()
    if writefile then
        pcall(function() writefile(ConfigFile, HttpService:JSONEncode(Config)) end)
    end
end

LoadConfig()

-- ============================================================
-- UTILITY & FIREBASE ENGINE
-- ============================================================
local function AturDataFirebase(path, data)
    if not writefile then return nil end
    local url = FirebaseURL .. path .. ".json"
    local dataJson = HttpService:JSONEncode(data)
    local hasil = nil
    pcall(function()
        hasil = request({
            Url = url,
            Method = "PUT",
            Headers = {["Content-Type"] = "application/json"},
            Body = dataJson
        })
    end)
    return hasil
end

local function AmbilDataFirebase(path)
    if not writefile then return {} end
    local url = FirebaseURL .. path .. ".json"
    local hasil = nil
    pcall(function()
        hasil = request({Url = url, Method = "GET"})
    end)
    if hasil and hasil.Success and hasil.Body then
        local ok, data = pcall(function() return HttpService:JSONDecode(hasil.Body) end)
        if ok and type(data) == "table" then return data end
    end
    return {}
end

local function LompatServer(jobId)
    if sedangTeleport then return end
    sedangTeleport = true
    pcall(function()
        if jobId and jobId ~= "" and jobId ~= game.JobId then
            TeleportService:TeleportToPlaceInstance(game.PlaceId, jobId, LocalPlayer)
        else
            local x = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"))
            for _, s in ipairs(x.data) do
                if s.playing < s.maxPlayers and s.id ~= game.JobId then
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, s.id, LocalPlayer)
                    break
                end
            end
        end
    end)
    task.wait(5)
    sedangTeleport = false
end

local function HapusPetLamaFirebase()
    local tNow = os.time()
    local dataLama = AmbilDataFirebase("ServerPets")
    local dataBaru = {}
    local adaPerubahan = false
    
    for jId, sData in pairs(dataLama) do
        if type(sData) == "table" and type(sData.Pets) == "table" then
            local listPetValid = {}
            for _, p in ipairs(sData.Pets) do
                if p.SpawnedAt and (tNow - p.SpawnedAt) < PET_LIFETIME then
                    table.insert(listPetValid, p)
                else
                    adaPerubahan = true
                end
            end
            if #listPetValid > 0 then
                dataBaru[jId] = {Pets = listPetValid, UpdatedAt = sData.UpdatedAt or tNow}
            else
                adaPerubahan = true
            end
        end
    end
    if adaPerubahan then
        AturDataFirebase("ServerPets", dataBaru)
    end
end

local function KirimPetKeFirebase(namaPet)
    local tNow = os.time()
    local dataLama = AmbilDataFirebase("ServerPets/" .. game.JobId)
    local listPet = {}
    if dataLama and type(dataLama.Pets) == "table" then
        listPet = dataLama.Pets
    end
    
    local sudahAda = false
    for _, p in ipairs(listPet) do
        if p.Name == namaPet and (tNow - p.SpawnedAt) < 30 then
            sudahAda = true
            break
        end
    end
    
    if not sudahAda then
        table.insert(listPet, {Name = namaPet, SpawnedAt = tNow})
        AturDataFirebase("ServerPets/" .. game.JobId, {Pets = listPet, UpdatedAt = tNow})
    end
end

