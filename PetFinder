            end
        end
        pcall(function() workspace.Terrain.Decoration = false end)
    end

    -- [3] Hapus folder visual di workspace (AMAN — tidak menyentuh folder Map)
    local NUKE_WS = {
        "BirdVisuals","Birds","BlizzardBeams","GnomeVisuals","Gnomes",
        "Handles","LightningEffects","DroppedItems","Fences","Folder",
        "Middle","HolderFolders","PottedPlantVisuals","RainDrops",
        "RainSplashes","StormRainDrops","StormSplashes","Teleports",
        "Temporary","_Gardens","_PetVisualClient","NPCS","CapyBara",
    }
    local function NukeWorkspace()
        for _, nama in ipairs(NUKE_WS) do
            local f = workspace:FindFirstChild(nama)
            if f then pcall(function() f:Destroy() end) end
        end
        workspace.ChildAdded:Connect(function(child)
            for _, nama in ipairs(NUKE_WS) do
                if child.Name == nama then
                    task.wait(0.1); pcall(function() child:Destroy() end)
                end
            end
        end)
    end

    -- [4] Bersihkan Plot di Gardens (tanaman + buah)
    local FOLDER_BUAH = {
        "Fruits","FruitSpawnLocations","FruitVisuals",
        "PlantVisuals","GrowthVisuals","Effects","Plants",
    }
    local function IsFolderBuah(nama)
        for _, fb in ipairs(FOLDER_BUAH) do
            if nama == fb then return true end
        end
        return false
    end
    local function MatikanObj(obj)
        pcall(function()
            if obj:IsA("BasePart") or obj:IsA("MeshPart") or obj:IsA("UnionOperation") then
                obj.Transparency = 1; obj.CastShadow = false
            end
            if obj:IsA("Decal") or obj:IsA("Texture") then obj.Transparency = 1 end
            if obj:IsA("ParticleEmitter") or obj:IsA("Beam") or obj:IsA("Trail") or
               obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Sparkles") then obj.Enabled = false end
            if obj:IsA("PointLight") or obj:IsA("SurfaceLight") or obj:IsA("SpotLight") then obj.Enabled = false end
            if obj:IsA("Sound") then obj.Volume = 0 end
        end)
    end
    local function BersihkanPlot(plot)
        for _, desc in ipairs(plot:GetDescendants()) do
            if IsFolderBuah(desc.Name) then pcall(function() desc:Destroy() end) end
        end
        for _, desc in ipairs(plot:GetDescendants()) do MatikanObj(desc) end
        if plot:IsA("BasePart") then pcall(function() plot.Transparency = 1; plot.CastShadow = false end) end
        plot.DescendantAdded:Connect(function(desc)
            task.wait(0.02)
            if not desc or not desc.Parent then return end
            if IsFolderBuah(desc.Name) or (desc.Parent and IsFolderBuah(desc.Parent.Name)) then
                pcall(function() desc:Destroy() end); return
            end
            MatikanObj(desc)
        end)
    end
    local function HapusPlot()
        local Gardens = workspace:FindFirstChild("Gardens") or workspace:WaitForChild("Gardens", 10)
        if not Gardens then return end
        for _, child in ipairs(Gardens:GetChildren()) do
            if string.match(child.Name, "^Plot") then BersihkanPlot(child) end
        end
        Gardens.ChildAdded:Connect(function(child)
            if string.match(child.Name, "^Plot") then task.wait(0.2); BersihkanPlot(child) end
        end)
    end

    BypassLoading()
    task.wait(0.05)
    OptimRender()
    task.wait(0.05)
    NukeWorkspace()
    task.wait(0.05)
    HapusPlot()
    print("[DScripts V5] Anti Lag & Bypass Loading aktif ✔")
end)

