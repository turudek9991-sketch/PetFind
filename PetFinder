-- ============================================================
-- HELPER: Format angka (10000 → 10,000)
-- ============================================================
local function FormatAngka(n)
    local s, result, count = tostring(math.floor(n)), "", 0
    for i = #s, 1, -1 do
        if count > 0 and count % 3 == 0 then result = "," .. result end
        result = s:sub(i, i) .. result
        count  = count + 1
    end
    return result
end

-- ============================================================
-- FIREBASE: Klaim server (anti-collision antar bot)
-- ============================================================
local KLAIM_TTL = 30 -- detik

local function KlaimServer(targetJobId)
    pcall(function()
        HttpRequest({
            Url     = FirebaseURL .. "BotClaims/" .. BOT_ID .. ".json",
            Method  = "PUT",
            Headers = { ["Content-Type"] = "application/json" },
            Body    = HttpService:JSONEncode({
                TargetJobId = targetJobId,
                Timestamp   = os.time(),
            }),
        })
    end)
end

local function HapusKlaim()
    pcall(function()
        HttpRequest({
            Url    = FirebaseURL .. "BotClaims/" .. BOT_ID .. ".json",
            Method = "DELETE",
        })
    end)
end

local function AmbilServerDiklaim()
    local diklaim = {}
    local ok, res = pcall(function()
        return HttpRequest({ Url = FirebaseURL .. "BotClaims.json", Method = "GET" })
    end)
    if not ok or not res or not res.Body then return diklaim end

    local okD, data = pcall(function() return HttpService:JSONDecode(res.Body) end)
    if not okD or type(data) ~= "table" then return diklaim end

    local now = os.time()
    for botId, info in pairs(data) do
        if botId ~= BOT_ID 
        and type(info) == "table"
        and type(info.TargetJobId) == "string"
        and type(info.Timestamp) == "number"
        and (now - info.Timestamp) < KLAIM_TTL then -- klaim masih fresh
            diklaim[info.TargetJobId] = true
        end
    end
    return diklaim
end

