local function FormatAngka(n)
    local s, result, count = tostring(math.floor(n)), "", 0
    for i = #s, 1, -1 do
        if count > 0 and count % 3 == 0 then result = "," .. result end
        result = s:sub(i, i) .. result
        count  = count + 1
    end
    return result
end

-- ============================================================
-- FIREBASE CLOUD TRACKING
-- ============================================================
local KLAIM_TTL = 30

local function KlaimServer(targetJobId)
    pcall(function()
        HttpRequest({
            Url     = FirebaseURL .. "BotClaims/" .. BOT_ID .. ".json",
            Method  = "PUT",
            Headers = { ["Content-Type"] = "application/json" },
            Body    = HttpService:JSONEncode({ TargetJobId = targetJobId, Timestamp = os.time(), DeviceUser = LocalPlayer.Name }),
        })
    end)
end

local function HapusKlaim()
    pcall(function() HttpRequest({ Url = FirebaseURL .. "BotClaims/" .. BOT_ID .. ".json", Method = "DELETE" }) end)
end

local function AmbilServerDiklaim()
    local diklaim = {}
    local ok, res = pcall(function() return HttpRequest({ Url = FirebaseURL .. "BotClaims.json", Method = "GET" }) end)
    if not ok or not res or not res.Body then return diklaim end
    local okD, data = pcall(function() return HttpService:JSONDecode(res.Body) end)
    if not okD or type(data) ~= "table" then return diklaim end
    local now = os.time()
    for botId, info in pairs(data) do
        if botId ~= BOT_ID and type(info) == "table"
        and type(info.TargetJobId) == "string"
        and type(info.Timestamp) == "number"
        and (now - info.Timestamp) < KLAIM_TTL then
            diklaim[info.TargetJobId] = true
        end
    end
    return diklaim
end

local function DaftarkanKehadiranAktif()
    pcall(function()
        HttpRequest({
            Url     = FirebaseURL .. "ActiveBots/" .. game.JobId .. ".json",
            Method  = "PUT",
            Headers = { ["Content-Type"] = "application/json" },
            Body    = HttpService:JSONEncode({ BotName = LocalPlayer.Name, Timestamp = os.time() }),
        })
    end)
end

local function AmbilDaftarBotAktif()
    local aktif = {}
    local ok, res = pcall(function() return HttpRequest({ Url = FirebaseURL .. "ActiveBots.json", Method = "GET" }) end)
    if not ok or not res or not res.Body then return aktif end
    local okD, data = pcall(function() return HttpService:JSONDecode(res.Body) end)
    if not okD or type(data) ~= "table" then return aktif end
    for jobId, _ in pairs(data) do aktif[jobId] = true end
    return aktif
end

local function HapusKehadiranAktif()
