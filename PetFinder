local WAKTU_VERIFIKASI = 30 -- detik tunggu konfirmasi masuk backpack
local sedangMemproses  = false -- kunci agar tidak proses 2 pet sekaligus

-- Cari pet di backpack berdasarkan nama (case-insensitive, partial match)
local function CariPetDiBackpack(namaPet)
    local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
    local char     = LocalPlayer.Character

    local function scanFolder(folder)
        if not folder then return false end
        for _, item in ipairs(folder:GetChildren()) do
            if string.find(item.Name:lower(), namaPet:lower()) then
                return true
            end
            -- Cek juga attribute/tag jika ada
            for _, desc in ipairs(item:GetDescendants()) do
                if string.find(desc.Name:lower(), namaPet:lower()) then
                    return true
                end
            end
        end
        return false
    end

    -- Cek di Backpack dan di karakter (equipped item)
    if scanFolder(backpack) then return true end
    if scanFolder(char) then return true end

    -- Cek juga di PlayerData / leaderstats jika game menyimpan di sana
    local playerData = LocalPlayer:FindFirstChild("PlayerData") or LocalPlayer:FindFirstChild("Data")
    if playerData then
        local petData = playerData:FindFirstChild("Pets") or playerData:FindFirstChild("OwnedPets")
        if petData then
            if scanFolder(petData) then return true end
        end
    end

    return false
end

-- Eksekusi tombol beli (tekan ProximityPrompt sekali saja, tidak loop)
local function TekanjPetPrompt(item)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local part = item:IsA("BasePart") and item
        or item:FindFirstChildWhichIsA("BasePart", true)
        or (item:IsA("Model") and item.PrimaryPart)
    if not part then return end

    -- Teleport ke pet
    root.CFrame = part.CFrame + Vector3.new(0, 3, 0)
    task.wait(0.05)

    -- Cari prompt
    local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
    if not prompt and item.Parent then
        prompt = item.Parent:FindFirstChildWhichIsA("ProximityPrompt", true)
    end
    if not prompt then return end

    -- Nolkan hold, tekan SEKALI
    prompt.HoldDuration = 0
    pcall(function() prompt:InputHoldBegin() end)
    task.wait(0.08)
    pcall(function() prompt:InputHoldEnd() end)
    if fireproximityprompt then
        pcall(function() fireproximityprompt(prompt) end)
    end
end

-- Countdown status di UI
local function JalankanCountdown(namaPet, totalDetik, onTick)
    for i = totalDetik, 1, -1 do
        SetStatus(
            "⏳ Loading beli " .. namaPet .. "... (" .. i .. "s)",
            Color3.fromRGB(255, 200, 50)
        )
        -- Cek tiap detik, jika sudah ada di backpack langsung return true
        for _ = 1, 10 do
            task.wait(0.1)
            if onTick and onTick() then return true end
        end
    end
    return false
end

CekPetLokal = function(item)
    if not item or not item.Parent then return end

    -- Jika sedang proses pet lain, skip (hindari race condition)
    if sedangMemproses then return end

    local namaLower   = item.Name:lower()
    local targetValid = nil

    for tName, aktif in pairs(Config.Targets) do
        if aktif and string.find(namaLower, tName:lower()) then
            targetValid = tName
            break
        end
    end

    if not targetValid then return end
    if not Config.AutoBuy then return end

    -- Anti Steal
    local petKey = tostring(item) .. "_" .. targetValid
    if Config.AntiSteal and PetSudahDibeli[petKey] then
        SetStatus("Skip " .. targetValid .. " (Anti Steal aktif)", C.TEXT_SEC)
        return
    end

    PetSudahDibeli[petKey] = true
    sedangMemproses        = true

    task.spawn(function()
        -- Rekam jumlah pet di backpack SEBELUM beli (untuk bandingkan nanti)
        local backpackSebelum = LocalPlayer:FindFirstChildOfClass("Backpack")
        local jumlahSebelum   = backpackSebelum and #backpackSebelum:GetChildren() or 0

        SetStatus("🎯 " .. targetValid .. " ditemukan! Menekan tombol beli...", Color3.fromRGB(255, 200, 50))

        -- Tekan tombol beli SEKALI
        TekanjPetPrompt(item)

        -- Mulai countdown 30 detik sambil polling backpack
        local sukses = JalankanCountdown(targetValid, WAKTU_VERIFIKASI, function()
            -- Cek 1: nama pet ada di backpack
            if CariPetDiBackpack(targetValid) then return true end
            -- Cek 2: jumlah item di backpack bertambah (fallback)
            local bp = LocalPlayer:FindFirstChildOfClass("Backpack")
            if bp and #bp:GetChildren() > jumlahSebelum then return true end
            return false
        end)

        -- ====== HASIL ======
        if sukses then
            SetStatus("✅ " .. targetValid .. " BERHASIL DIBELI!", C.GREEN)
            task.spawn(function()
                KirimNotifDiscord(targetValid, true)  -- true = sukses
            end)
        else
            SetStatus("❌ " .. targetValid .. " GAGAL / tidak masuk tas (30s)", Color3.fromRGB(220, 60, 60))
            task.spawn(function()
                KirimNotifDiscord(targetValid, false) -- false = gagal
            end)
            -- Reset flag jika Anti Steal off agar bisa coba lagi
            if not Config.AntiSteal then
                PetSudahDibeli[petKey] = nil
            end
        end

        sedangMemproses = false
    end)
end

