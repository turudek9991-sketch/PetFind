-- ============================================================
-- ENGINE SAVE / LOAD CONFIG JSON
-- ============================================================
local function LoadConfig()
    if isfile and readfile and isfile(ConfigFile) then
        local ok, data = pcall(function() return HttpService:JSONDecode(readfile(ConfigFile)) end)
        if ok and type(data) == "table" then
            if data.AutoBuy ~= nil then Config.AutoBuy = data.AutoBuy end
            if data.Targets and type(data.Targets) == "table" then
                for nama, status in pairs(data.Targets) do
                    if Config.Targets[nama] ~= nil then
                        Config.Targets[nama] = status
                    end
                end
            end
            print("[Auto Buy] Berhasil memuat konfigurasi dari file!")
        end
    end
end

local function SaveConfig()
    if writefile then
        local ok, err = pcall(function() 
            writefile(ConfigFile, HttpService:JSONEncode(Config)) 
        end)
        if ok then
            print("[Auto Buy] Konfigurasi berhasil disimpan!")
        else
            warn("[Auto Buy] Gagal menyimpan konfigurasi: ", err)
        end
    end
end

