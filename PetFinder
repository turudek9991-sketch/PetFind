            end
            Gardens.ChildAdded:Connect(function(child)
                if string.match(child.Name, "^Plot") then task.wait(0.2); BersihkanPlot(child) end
            end)
        end)
    end

    BypassLoading()
    OptimRender()
    NukeWorkspace()
    HapusPlot()
    print("[DScripts V5] Anti Lag Gabungan Aktif ✔")
end)

