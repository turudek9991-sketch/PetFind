local teleportBerhasil = false

TeleportService.TeleportInitFailed:Connect(function(player, reason)
    if player == LocalPlayer then
        warn("[Bot] TeleportInitFailed: " .. tostring(reason))
        teleportBerhasil = false
    end
end)

local function AcakTabel(t)
    for i = #t, 2, -1 do
        local j = math.random(1, i)
        t[i], t[j] = t[j], t[i]
    end
    return t
end

local function AmbilSemuaServerKosong()
    local list   = {}
    local cursor = ""
    repeat
        local url = "https://games.roblox.com/v1/games/" .. game.PlaceId
            .. "/servers/Public?sortOrder=Asc&limit=100"
            .. (cursor ~= "" and ("&cursor=" .. cursor) or "")

        local ok, result = pcall(function()
            return HttpService:JSONDecode(game:HttpGet(url))
        end)
        if not ok or not result or type(result.data) ~= "table" then break end

        for _, srv in ipairs(result.data) do
            if srv.id ~= game.JobId
            and not shared.VisitedServers[srv.id] -- MODIFIKASI: Jangan masuki server history yang sama
            and type(srv.playing) == "number"
            and type(srv.maxPlayers) == "number"
            and srv.playing < srv.maxPlayers then
                table.insert(list, srv.id)
            end
        end

        cursor = (type(result.nextPageCursor) == "string" and result.nextPageCursor) or ""
    until cursor == "" or cursor == "null"

    return list
end

local function HopServer()
    teleportBerhasil = false
    HapusKlaim()  -- bersihkan klaim lama sebelum mulai

    print("[Bot] Memulai hop server...")

    while not teleportBerhasil do
        local servers = AmbilSemuaServerKosong()
        if #servers == 0 then
            print("[Bot] Tidak ada server kosong baru, reset history filter & retry...")
            shared.VisitedServers = {} -- Reset penampung jika semua opsi server habis
            task.wait(5)
            continue
        end

        AcakTabel(servers)
        local serverDiklaim = AmbilServerDiklaim()
        print(string.format("[Bot] %d server kosong, %d diklaim bot lain", 
            #servers, (function() local n=0 for _ in pairs(serverDiklaim) do n=n+1 end return n end)()))

        local adaCandidateBaru = false

        for _, jobId in ipairs(servers) do
            if teleportBerhasil then break end
            if serverDiklaim[jobId] then
                print("[Bot] Skip " .. string.sub(jobId, 1, 8) .. "… (diklaim bot lain)")
                continue
            end

            adaCandidateBaru = true
            KlaimServer(jobId)
            print("[Bot] Klaim + teleport ke " .. string.sub(jobId, 1, 8) .. "…")

            local ok, err = pcall(function()
                TeleportService:TeleportToPlaceInstance(game.PlaceId, jobId, LocalPlayer)
            end)

            if ok then
                task.wait(10)
                if not teleportBerhasil then
                    print("[Bot] Timeout teleport, hapus klaim, coba server lain...")
                    HapusKlaim()
                    task.wait(1)
                end
            else
                warn("[Bot] pcall error: " .. tostring(err))
                HapusKlaim()
                task.wait(1)
            end
        end

        if not teleportBerhasil then
            task.wait(5)
        end
    end
end

-- ============================================================
-- UTILITY SCANNER modular
-- ============================================================
local function JalankanScanWorkspace(PetFolder)
    local paket       = {}
    local PlayerCount = #Players:GetPlayers()
    local MaxPlayers  = Players.MaxPlayers

    for _, obj in ipairs(PetFolder:GetChildren()) do
        local namaLower = obj.Name:lower()
        for _, namaPet in ipairs(ListNamaPet) do
            if string.find(namaLower, namaPet:lower()) then
                if not paket[namaPet] then
                    local part = obj:IsA("BasePart") and obj
                              or obj:FindFirstChildWhichIsA("BasePart", true)
                              or obj.PrimaryPart
                    if part then
                        local meta = PetMetadata[namaPet] or { Tier = 1 }
                        paket[namaPet] = {
                            PetName        = namaPet,
                            Tier           = meta.Tier,
                            Rarity         = meta.Rarity or "Common",
                            JobId          = game.JobId,
                            PlaceId        = game.PlaceId,
                            Position       = { X = part.CFrame.X, Y = part.CFrame.Y, Z = part.CFrame.Z },
                            Timestamp      = os.time(),
                            CurrentPlayers = PlayerCount,
                            MaxPlayers     = MaxPlayers,
                        }
                    end
                end
                break
            end
        end
    end
    return paket
end

-- ============================================================
-- FUNGSI UTAMA: Scan → Firebase → Discord → Hop
-- ============================================================
local function ScanDanHop()
    -- MODIFIKASI FIX: Ganti WaitForChild kaku dengan wait safety loop agar executor tidak crash mendarat
    local MapFolder = workspace:WaitForChild("Map", 20)
    local PetFolder = MapFolder and MapFolder:WaitForChild("WildPetSpawns", 20)

    if not PetFolder then
        warn("[Bot] WildPetSpawns tidak ditemukan, hop...")
        HopServer()
        return
    end

    -- MODIFIKASI BARU: Jika server penuh, bot langsung kabur tanpa membuang kuota data API
    if #Players:GetPlayers() >= Players.MaxPlayers then
        print("[Bot Skip] Server Full. Langsung pindah...")
        HopServer()
        return
    end

    local paket = JalankanScanWorkspace(PetFolder)
    local adaPetBernilaiTinggi = false

    -- Cek kriteria Tier 5 (Mythic) atau Tier 6 (Super)
    for _, data in pairs(paket) do
        if data.Tier and data.Tier >= 5 then
            adaPetBernilaiTinggi = true
            break
        end
    end

    if next(paket) ~= nil then
        KirimFirebase(paket)
        print("[Bot] Firebase: OK")
        KirimDiscord(paket, #Players:GetPlayers(), Players.MaxPlayers, game.JobId, game.PlaceId)
        print("[Bot] Discord: OK")
        
        -- MODIFIKASI FIX JEDA: Kasih napas 1.5 detik agar paket HTTP tersalurkan penuh ke internet
        task.wait(1.5)

        -- MODIFIKASI UTAMA: CAMPING SYSTEM (JANGAN HOP JIKA ADA MYTHIC/SUPER)
        if adaPetBernilaiTinggi then
            print("[Bot Mode Camp] Mengunci posisi server karena ada target berharga...")
            while adaPetBernilaiTinggi do
                task.wait(3) -- Re-scan ulang kondisi map per 3 detik
                local updatePaket = JalankanScanWorkspace(PetFolder)
                
                adaPetBernilaiTinggi = false
                for _, data in pairs(updatePaket) do
                    if data.Tier and data.Tier >= 5 then
                        adaPetBernilaiTinggi = true
                        break
                    end
                end
                
                if adaPetBernilaiTinggi then
                    KirimFirebase(updatePaket) -- Refresh perpanjangan status data di radar panel
                else
                    print("[Bot Mode Camp] Target sudah hilang/di-snipe. Bersihkan API & Hop.")
                    HapusDataServer()
                end
            end
        else
            -- Pet Tier rendah biasa (Tier 1-4): Tunggu 4 detik bawaan aslimu, hapus data, lalu pergi
            task.wait(4)
            HapusDataServer()
        end
    else
        print("[Bot] Tidak ada pet ditemukan.")
        task.wait(0.5)
    end

    HopServer()
end

