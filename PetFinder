        pcall(function() workspace.Terrain.Decoration = false end)
    end

    -- [3] Hapus folder visual di workspace (Aman, tidak menyentuh Map/WildPetSpawns)
    local NUKE_WS = {
        "BirdVisuals","Birds","BlizzardBeams","GnomeVisuals","Gnomes",
        "Handles","LightningEffects","DroppedItems","Fences","Folder",
        "Middle","HolderFolders","PottedPlantVisuals","RainDrops",
        "RainSplashes","StormRainDrops","StormSplashes","Teleports",
        "Temporary","_Gardens","_PetVisualClient","NPCS","CapyBara",
    }
    local function NukeWorkspace()
        for _, nama in ipairs(NUKE_WS) do
            pcall(function()
                local f = workspace:FindFirstChild(nama)
                if f then f:Destroy() end
            end)
        end
        workspace.ChildAdded:Connect(function(child)
            pcall(function()
                for _, nama in ipairs(NUKE_WS) do
