local function KirimNotifDiscord(namaPet, sukses)
    local httpFunc = HttpRequest or request or (syn and syn.request) or http_request or nil
    if not httpFunc then
        warn("[Webhook] Tidak ada fungsi HTTP yang tersedia!")
        return
    end

    local judul, warnaDec, emoji
    if sukses then
        judul    = "✅ Pembelian Berhasil!"
        warnaDec = 5763719
        emoji    = "🎉"
    else
        judul    = "❌ Pembelian Gagal"
        warnaDec = 15548997
        emoji    = "😢"
    end

    local deskripsi = emoji .. " **Nama Pet:** `" .. namaPet .. "`\n"
        .. "**Status:** " .. (sukses and "✅ Berhasil (Tame terdeteksi)" or "❌ Timeout 30 detik, Tame tidak muncul") .. "\n"
        .. "**Server Job ID:** `" .. tostring(game.JobId) .. "`\n"
        .. "**Waktu:** <t:" .. os.time() .. ":R>"

    local payload = HttpService:JSONEncode({
        username   = "Pet Finder Bot 🌱",
        avatar_url = "https://i.imgur.com/AfFp7pu.png",
        embeds = {{
            title       = judul,
            description = deskripsi,
            color       = warnaDec,
            footer      = { text = "Pet Finder V34 · Grow a Garden" },
            timestamp   = os.date("!%Y-%m-%dT%H:%M:%SZ"),
        }}
    })

    local ok, err = pcall(function()
        httpFunc({
            Url     = DISCORD_WEBHOOK_URL,
            Method  = "POST",
            Headers = { ["Content-Type"] = "application/json" },
