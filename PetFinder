-- CORE ENGINE V34: LOOP BUY + DETEKSI ANIMASI TAME
-- ============================================================

local WAKTU_TIMEOUT    = 100    -- detik maksimum menunggu pet masuk backpack
local INTERVAL_TEKAN   = 0.2   -- jeda antar tekan BuyPrompt (lebih cepat)
local WAKTU_CEK_BACKPACK = 0.2 -- polling backpack setiap N detik
local sedangMemproses  = false

-- Snapshot jumlah item backpack sebelum beli (untuk deteksi masuk)
local function HitungIsiBackpack()
    local bp   = LocalPlayer:FindFirstChildOfClass("Backpack")
    local char = LocalPlayer.Character
    local count = 0
    if bp then
        for _, v in ipairs(bp:GetChildren()) do count += 1 end
    end
    -- Cek juga folder Pets / OwnedPets di PlayerData jika ada
    local pd = LocalPlayer:FindFirstChild("PlayerData") or LocalPlayer:FindFirstChild("Data")
    if pd then
        local pets = pd:FindFirstChild("Pets") or pd:FindFirstChild("OwnedPets")
        if pets then
            for _, v in ipairs(pets:GetChildren()) do count += 1 end
        end
    end
    return count
end

-- ============================================================
-- FUNGSI DETEKSI ANIMASI TAME
-- Cek apakah animasi "Tame" sedang aktif di model pet
-- Dari foto: Tame ada di dalam model pet (WildPet_Frog_...) > Animations > Tame
-- Atau langsung sebagai anak dari model (bisa keduanya)
-- ============================================================
local function CekAnimasiTame(petModel)
    if not petModel or not petModel.Parent then return false end

    -- Cek 1: Animations folder berisi "Tame"
    local animFolder = petModel:FindFirstChild("Animations")
    if animFolder then
        local tame = animFolder:FindFirstChild("Tame")
        if tame then
            -- Animasi Tame ada, tapi apakah sedang diputar?
            -- Cek AnimationController apakah playing Tame
            local animController = petModel:FindFirstChildWhichIsA("AnimationController")
            if animController then
                local animator = animController:FindFirstChildWhichIsA("Animator")
                if animator then
                    local tracks = animator:GetPlayingAnimationTracks()
                    for _, track in ipairs(tracks) do
                        if track.Animation and
                           (track.Animation.AnimationId == tame.AnimationId or
                            string.find(track.Name:lower(), "tame")) then
                            return true
                        end
                    end
                end
            end

            -- Cek alternatif: Humanoid animator di RootPart
            local rootPart = petModel:FindFirstChild("RootPart") or petModel.PrimaryPart
            if rootPart then
                local hum = petModel:FindFirstChildWhichIsA("Humanoid")
                if hum then
                    local animator = hum:FindFirstChildWhichIsA("Animator")
                    if animator then
                        local tracks = animator:GetPlayingAnimationTracks()
                        for _, track in ipairs(tracks) do
                            if track.Animation and
                               (track.Animation.AnimationId == tame.AnimationId or
                                string.find(track.Name:lower(), "tame")) then
                                return true
                            end
                        end
                    end
                end
            end
        end
    end

    -- Cek 2: Ada objek bernama "Tame" yang muncul sebagai tanda sukses
    -- (beberapa game spawns object "Tame" saat berhasil)
    local tameObj = petModel:FindFirstChild("Tame", true)
    if tameObj then
        -- Jika Tame adalah BoolValue/StringValue yang di-set true
        if tameObj:IsA("BoolValue") and tameObj.Value == true then
            return true
        end
        -- Jika Tame adalah Part/Model yang muncul (tanda visual)
        if tameObj:IsA("Part") or tameObj:IsA("Model") or tameObj:IsA("SpecialMesh") then
            return true
        end
    end

    -- Cek 3: BuyPrompt hilang (disabled/destroyed = pet sudah dibeli orang lain atau berhasil)
    local buyPrompt = petModel:FindFirstChild("BuyPrompt", true)
    if not buyPrompt or not buyPrompt.Enabled then
        -- Verifikasi tambahan: pastikan Tame animation sedang running
        local animController = petModel:FindFirstChildWhichIsA("AnimationController", true)
        if animController then
            local animator = animController:FindFirstChildWhichIsA("Animator")
            if animator then
                local tracks = animator:GetPlayingAnimationTracks()
                for _, track in ipairs(tracks) do
                    if string.find(track.Name:lower(), "tame") then
                        return true
                    end
                end
            end
        end
    end

    return false
end

-- ============================================================
-- FUNGSI TEKAN BUYPROMPT (dipakai berulang di loop)
-- ============================================================
local function TekanjPetPrompt(petModel)
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    -- Ambil posisi pet
    local part = petModel:IsA("BasePart") and petModel
        or petModel:FindFirstChildWhichIsA("BasePart", true)
        or petModel.PrimaryPart
    if not part then return end

    -- Teleport ke dekat pet
    root.CFrame = part.CFrame + Vector3.new(0, 3, 0)
    task.wait(0.05)

    -- Cari BuyPrompt
    local prompt = petModel:FindFirstChild("BuyPrompt", true)
    if not prompt then
        -- Cek di parent juga (jaga-jaga)
        if petModel.Parent then
            prompt = petModel.Parent:FindFirstChild("BuyPrompt", true)
        end
    end
    if not prompt then return end

    -- Pastikan prompt masih enabled sebelum ditekan
    if not prompt.Enabled then return end

    -- Nolkan hold duration dan tekan
    prompt.HoldDuration = 0
    pcall(function() prompt:InputHoldBegin() end)
    task.wait(0.05)
    pcall(function() prompt:InputHoldEnd() end)

    -- Gunakan fireproximityprompt jika tersedia (lebih reliable)
    if fireproximityprompt then
        pcall(function() fireproximityprompt(prompt) end)
    end
end

-- ============================================================
-- FUNGSI UTAMA: LOOP BUY SAMPAI PET MASUK BACKPACK / TIMEOUT
-- Thread A : tekan BuyPrompt setiap INTERVAL_TEKAN detik
-- Thread B : polling backpack setiap WAKTU_CEK_BACKPACK detik
-- Notif Discord dikirim HANYA setelah backpack terkonfirmasi bertambah
-- ============================================================
local function MulaiBuyLoop(petModel, targetName, petKey)
    local waktuMulai = os.clock()
    local tekanKe    = 0
    local berhasil   = false
    local jumlahAwal = HitungIsiBackpack()  -- snapshot sebelum beli

    -- Thread B: polling backpack secara paralel
    task.spawn(function()
        while not berhasil and (os.clock() - waktuMulai) < WAKTU_TIMEOUT + 2 do
            task.wait(WAKTU_CEK_BACKPACK)
            if HitungIsiBackpack() > jumlahAwal then
                berhasil = true
            end
        end
    end)

    -- Thread A: loop tekan BuyPrompt
    while os.clock() - waktuMulai < WAKTU_TIMEOUT do
        if not petModel or not petModel.Parent then break end
        if not Config.AutoBuy then break end
        if berhasil then break end

        tekanKe = tekanKe + 1
        local sisaWaktu = math.floor(WAKTU_TIMEOUT - (os.clock() - waktuMulai))
        SetStatus(
            "🔄 Tekan #" .. tekanKe .. " · " .. targetName .. " (" .. sisaWaktu .. "s)",
            Color3.fromRGB(255, 200, 50)
        )

        TekanjPetPrompt(petModel)
        task.wait(INTERVAL_TEKAN)

        if berhasil then break end
    end

    -- Buffer kecil agar thread B sempat konfirmasi terakhir
    if not berhasil then task.wait(0.5) end
    if HitungIsiBackpack() > jumlahAwal then berhasil = true end

    -- ====== HASIL ======
    if berhasil then
        SetStatus("✅ " .. targetName .. " MASUK BACKPACK! (" .. tekanKe .. "x tekan, " .. string.format("%.1f", os.clock() - waktuMulai) .. "s)", C.GREEN)
        print("[Pet Finder V35] SUKSES:", targetName, "| Tekan:", tekanKe, "| Waktu:", string.format("%.1f", os.clock() - waktuMulai) .. "s")

        -- Notif dikirim HANYA setelah backpack terkonfirmasi bertambah
        task.spawn(function() KirimNotifDiscord(targetName, true) end)

        PetSudahDibeli[petKey] = true
        sedangMemproses = false
        return
    end

    -- GAGAL / TIMEOUT
    SetStatus("❌ " .. targetName .. " TIMEOUT — tidak masuk backpack dalam " .. WAKTU_TIMEOUT .. "s", Color3.fromRGB(220, 60, 60))
    print("[Pet Finder V35] GAGAL:", targetName, "| Total tekan:", tekanKe)

    task.spawn(function() KirimNotifDiscord(targetName, false) end)

    if not Config.AntiSteal then
        PetSudahDibeli[petKey] = nil
    end

    sedangMemproses = false
end

-- ============================================================
-- FUNGSI CEK PET (dipanggil saat pet muncul)
-- ============================================================
CekPetLokal = function(item)
    if not item or not item.Parent then return end
    if sedangMemproses then return end

    local namaLower   = item.Name:lower()
    local targetValid = nil

    for tName, aktif in pairs(Config.Targets) do
        if aktif and string.find(namaLower, tName:lower()) then
            targetValid = tName
            break
        end
    end

    if not targetValid then return end
    if not Config.AutoBuy then return end

    -- Pastikan objek adalah model pet (bukan part acak)
    local petModel = item
    if not item:IsA("Model") then
        petModel = item.Parent
        if not petModel or not petModel:IsA("Model") then return end
    end

    -- Pastikan ada BuyPrompt (tanda ini memang pet yang bisa dibeli)
    local buyPrompt = petModel:FindFirstChild("BuyPrompt", true)
    if not buyPrompt then return end

    -- Anti Steal: skip jika sudah pernah diproses
    local petKey = tostring(petModel) .. "_" .. targetValid
    if Config.AntiSteal and PetSudahDibeli[petKey] then
        SetStatus("Skip " .. targetValid .. " (Anti Steal aktif)", C.TEXT_SEC)
        return
    end

    PetSudahDibeli[petKey] = true -- tandai dulu agar tidak diproses 2x
    sedangMemproses        = true

    SetStatus("🎯 " .. targetValid .. " ditemukan! Memulai buy loop...", Color3.fromRGB(100, 200, 255))
    print("[Pet Finder V35] Target ditemukan:", targetValid, "| Model:", petModel.Name)

    task.spawn(function()
        MulaiBuyLoop(petModel, targetValid, petKey)
    end)
end

-- ============================================================
-- HOOKING MAP & WILD PET SPAWNS
-- ============================================================
task.spawn(function()
    local ok, Map = pcall(function() return workspace:WaitForChild("Map", 15) end)
    if not ok or not Map then
        warn("[Pet Finder V35] Map tidak ditemukan dalam 15 detik!")
        return
    end

    local ok2, PetFolder = pcall(function() return Map:WaitForChild("WildPetSpawns", 15) end)
    if not ok2 or not PetFolder then
        warn("[Pet Finder V35] WildPetSpawns tidak ditemukan dalam 15 detik!")
        return
    end

    print("[Pet Finder V35] WildPetSpawns ditemukan, mulai monitoring...")

    local function HubungkanObjek(obj)
        if obj:IsDescendantOf(PetFolder) then
            CekPetLokal(obj)
        end
    end

    -- Scan yang sudah ada
    task.defer(function()
        for _, o in ipairs(PetFolder:GetDescendants()) do
            HubungkanObjek(o)
        end
    end)

    -- Real-time detection
    PetFolder.DescendantAdded:Connect(function(newObj)
        HubungkanObjek(newObj)
    end)
end)

