local teleportBerhasil = false
TeleportService.TeleportInitFailed:Connect(function(player, _)
    if player == LocalPlayer then teleportBerhasil = false end
end)

local function AcakTabel(t)
    for i = #t, 2, -1 do local j = math.random(1, i) t[i], t[j] = t[j], t[i] end
    return t
end

local function AmbilSemuaServerKosong()
    local list   = {}
    local cursor = ""
    repeat
        local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
            .. (cursor ~= "" and ("&cursor=" .. cursor) or "")
        local ok, result = pcall(function() return HttpService:JSONDecode(game:HttpGet(url)) end)
        if not ok or not result or type(result.data) ~= "table" then break end
        for _, srv in ipairs(result.data) do
            if srv.id ~= game.JobId
                and not VisitedServers[srv.id]
                and type(srv.playing) == "number"
                and type(srv.maxPlayers) == "number"
                and srv.playing < srv.maxPlayers then
                table.insert(list, srv.id)
            end
        end
        cursor = (type(result.nextPageCursor) == "string" and result.nextPageCursor) or ""
    until cursor == "" or cursor == "null"
    return list
end

local function HopServer()
    teleportBerhasil = false
    HapusKlaim()
    HapusKehadiranAktif()
    print("[Bot] Memulai hop server...")
    while not teleportBerhasil do
        local servers = AmbilSemuaServerKosong()
        if #servers == 0 then
            VisitedServers = {}
            task.wait(4)
            continue
        end
        AcakTabel(servers)
        local serverDiklaim  = AmbilServerDiklaim()
        local serverBotAktif = AmbilDaftarBotAktif()

        for _, jobId in ipairs(servers) do
            if teleportBerhasil then break end
            if serverDiklaim[jobId] or serverBotAktif[jobId] then continue end

            KlaimServer(jobId)
            local ok = pcall(function()
                TeleportService:TeleportToPlaceInstance(game.PlaceId, jobId, LocalPlayer)
            end)
            if ok then
                task.wait(10)
                if not teleportBerhasil then HapusKlaim(); task.wait(1) end
            else
                HapusKlaim(); task.wait(1)
            end
        end
        if not teleportBerhasil then task.wait(4) end
    end
end

-- ============================================================
-- SCANNER — FORMAT: WildPet_{NamaPet}_WildPet_{UUID}
-- ============================================================
local function ExtrakNamaPetDariNama(namaObj)
    -- Format: WildPet_Frog_WildPet_UUID atau WildPet_GoldenDragonfly_WildPet_UUID
    -- Ambil bagian setelah "WildPet_" pertama, sebelum "_WildPet_" kedua
    local petPart = namaObj:match("^WildPet_(.+)_WildPet_")
    if petPart then return petPart end

    -- Fallback: coba match langsung nama pet dari metadata
    return nil
end

local function JalankanScanWorkspace(PetFolder)
    local paket       = {}
    local PlayerCount = #Players:GetPlayers()
    local MaxPlayers  = Players.MaxPlayers

    for _, obj in ipairs(PetFolder:GetChildren()) do
        -- Coba ekstrak nama pet dari format WildPet_xxx_WildPet_UUID
        local namaPetDiekstrak = ExtrakNamaPetDariNama(obj.Name)

        local namaPetDitemukan = nil

        if namaPetDiekstrak then
            -- Cek apakah nama yang diekstrak ada di metadata (exact match)
            if PetMetadata[namaPetDiekstrak] then
                namaPetDitemukan = namaPetDiekstrak
            else
                -- Coba case-insensitive match
                for _, namaMeta in ipairs(ListNamaPet) do
                    if namaMeta:lower() == namaPetDiekstrak:lower() then
                        namaPetDitemukan = namaMeta
                        break
                    end
                end
            end
        end

        -- Fallback: string.find seperti sebelumnya
        if not namaPetDitemukan then
            local namaLower = obj.Name:lower()
            for _, namaMeta in ipairs(ListNamaPet) do
                if string.find(namaLower, namaMeta:lower()) then
                    namaPetDitemukan = namaMeta
                    break
                end
            end
        end

        if namaPetDitemukan and not paket[namaPetDitemukan] then
            local part = obj:IsA("BasePart") and obj
                or obj:FindFirstChildWhichIsA("BasePart", true)
                or (obj:IsA("Model") and obj.PrimaryPart)
            if part then
                local meta = PetMetadata[namaPetDitemukan] or { Tier = 1 }
                paket[namaPetDitemukan] = {
                    PetName        = namaPetDitemukan,
                    Tier           = meta.Tier,
                    Rarity         = meta.Rarity or "Common",
                    JobId          = game.JobId,
                    PlaceId        = game.PlaceId,
                    Position       = { X = part.CFrame.X, Y = part.CFrame.Y, Z = part.CFrame.Z },
                    Timestamp      = os.time(),
                    CurrentPlayers = PlayerCount,
                    MaxPlayers     = MaxPlayers,
                }
                print("[Scanner] Pet ditemukan: " .. namaPetDitemukan .. " dari object: " .. obj.Name)
            end
        end
    end
    return paket
end

