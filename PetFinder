-- CORE ENGINE LOGIC: DETEKSI & SAKELAR BELI AUTOMATIS
-- ============================================================
CekPetLokal = function(item)
    if not item or not item.Parent then return end
    
    local namaLower = item.Name:lower()
    local targetValid = nil
    
    for tName, aktif in pairs(Config.Targets) do
        if aktif and string.find(namaLower, tName:lower()) then
            targetValid = tName
            break
        end
    end
    
    if not targetValid then return end
    
    -- Kirim log ke Database Firebase agar server lain tahu
    task.spawn(function() KirimPetKeFirebase(targetValid) end)
    
    -- Jika AutoHop Aktif, lakukan teleportasi instan ke server lain jika ini server pencari
    if Config.AutoHop then
        task.spawn(function() LompatServer() end)
        return
    end
    
    -- Proses Eksekusi Auto Buy jika sakelar utama aktif
    if not Config.AutoBuy then return end
    
    local part = item:IsA("BasePart") and item 
        or item:FindFirstChildWhichIsA("BasePart", true) 
        or item.PrimaryPart
        
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    
    if root and part then
        root.CFrame = part.CFrame
        task.wait(0.02)
        
        local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
        if prompt then
            prompt.HoldDuration = 0
            prompt:InputHoldBegin()
            task.wait(0.01)
            prompt:InputHoldEnd()
            if fireproximityprompt then pcall(function() fireproximityprompt(prompt) end) end
        end
    end
end

