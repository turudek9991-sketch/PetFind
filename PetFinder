-- INTERUPSI WORKSPACE
-- ============================================================
task.spawn(function()
    local ok, Map = pcall(function() return workspace:WaitForChild("Map", 15) end)
    if not ok or not Map then return end
    
    local ok2, PetFolder = pcall(function() return Map:WaitForChild("WildPetSpawns", 15) end)
    if not ok2 or not PetFolder then return end

    local function ProsesObjek(obj)
        if obj:IsA("Model") or obj:IsA("BasePart") then
            if obj:IsDescendantOf(PetFolder) then
                CekDanBeliPet(obj)
            end
        end
    end

    -- [1] Ambil Pet Lama (Membongkar folder Middle)
    task.defer(function()
        for _, obj in ipairs(PetFolder:GetDescendants()) do
            ProsesObjek(obj)
        end
    end)

    -- [2] Ambil Pet Baru yang Baru Saja Terspawn
    PetFolder.DescendantAdded:Connect(function(newDescendant)
        ProsesObjek(newDescendant)
    end)
    
    -- [3] Backup Loop Berkala (Check-up setiap 1 detik)
    task.spawn(function()
        while MainFrame.Parent do
            task.wait(1)
            if Config.AutoBuy then
                for _, obj in ipairs(PetFolder:GetDescendants()) do
                    ProsesObjek(obj)
                end
            end
        end
    end)
end)

