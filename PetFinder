-- ============================================================
-- DISCORD SYSTEM
-- ============================================================
local function KirimDiscord(paket, playerCount, maxPlayers, jobId, placeId)
    local topColor, topTier = 5763719, 0
    local petList = {}

    for namaPet, _ in pairs(paket) do
        local meta = PetMetadata[namaPet] or {}
        if (meta.Tier or 0) > topTier then
            topTier  = meta.Tier or 0
            topColor = meta.Color or 5763719
        end
        table.insert(petList, { Name = namaPet, Meta = meta })
    end

    table.sort(petList, function(a, b)
        if (a.Meta.Tier or 0) ~= (b.Meta.Tier or 0) then return (a.Meta.Tier or 0) > (b.Meta.Tier or 0) end
        return (a.Meta.Price or 0) > (b.Meta.Price or 0)
    end)

    local petLines = ""
    for _, e in ipairs(petList) do
        petLines = petLines .. string.format("• **%s** — %s · %s\n", e.Name, e.Meta.Rarity or "Common", FormatAngka(e.Meta.Price or 0))
    end

    local teleportScript = string.format(
        'game:GetService("TeleportService"):TeleportToPlaceInstance(%s, "%s", game:GetService("Players").LocalPlayer)',
        tostring(placeId), tostring(jobId)
    )

    local embed = {
        username = BotUsername,
        embeds   = {{
            title       = "Pet Spawn Spotted",
            description = string.format("**%d pet terdeteksi**\n\n%s", #petList, petLines),
            color       = topColor,
            fields      = {
                { name = "Players",         value = string.format("%d/%d", playerCount, maxPlayers), inline = true  },
                { name = "Place ID",        value = tostring(placeId),                               inline = true  },
                { name = "Server (Job ID)", value = string.format("`%s`", tostring(jobId)),          inline = false },
                { name = "Link Execute",    value = string.format("```lua\n%s\n```", teleportScript), inline = false },
            },
            footer    = { text = BotUsername .. " • Pet Finder" },
            timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ"),
        }}
    }

    pcall(function()
        HttpRequest({
            Url     = WebhookURL,
            Method  = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body    = HttpService:JSONEncode(embed),
        })
    end)
end

-- ============================================================
-- ADVANCED HOPPING MECHANICS
-- ============================================================
local teleportBerhasil = false
TeleportService.TeleportInitFailed:Connect(function(player, reason)
    if player == LocalPlayer then teleportBerhasil = false end
end)

local function AcakTabel(t)
    for i = #t, 2, -1 do
        local j = math.random(1, i)
        t[i], t[j] = t[j], t[i]
    end
    return t
end

local function AmbilSemuaServerKosong()
    local list   = {}
    local cursor = ""
    repeat
        local url = "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100" .. (cursor ~= "" and ("&cursor=" .. cursor) or "")
        local ok, result = pcall(function() return HttpService:JSONDecode(game:HttpGet(url)) end)
        if not ok or not result or type(result.data) ~= "table" then break end
        for _, srv in ipairs(result.data) do
            if srv.id ~= game.JobId and not shared.VisitedServers[srv.id] and type(srv.playing) == "number" and type(srv.maxPlayers) == "number" and srv.playing < srv.maxPlayers then
                table.insert(list, srv.id)
            end
        end
        cursor = (type(result.nextPageCursor) == "string" and result.nextPageCursor) or ""
    until cursor == "" or cursor == "null"
    return list
end

local function HopServer()
    teleportBerhasil = false
    HapusKlaim()
    HapusKehadiranAktif()
    while not teleportBerhasil do
        local servers = AmbilSemuaServerKosong()
        if #servers == 0 then
            shared.VisitedServers = {}
            task.wait(4)
            continue
        end
        AcakTabel(servers)
        local server运输Diklaim = AmbilServerDiklaim()
        local serverBotAktif = AmbilDaftarBotAktif()
        
        for _, jobId in ipairs(servers) do
            if teleportBerhasil then break end
            if server运输Diklaim[jobId] or serverBotAktif[jobId] then continue end
            
            KlaimServer(jobId)
            local ok, err = pcall(function() TeleportService:TeleportToPlaceInstance(game.PlaceId, jobId, LocalPlayer) end)
            if ok then
                task.wait(10)
                if not teleportBerhasil then HapusKlaim(); task.wait(1) end
            else
                HapusKlaim(); task.wait(1)
            end
        end
        if not teleportBerhasil then task.wait(4) end
    end
end

-- ============================================================
-- SCANNER SYSTEM
-- ============================================================
local function HitungTotalPetDiWorkspace(PetFolder)
    return #PetFolder:GetChildren()
end

local function JalankanScanWorkspace(PetFolder)
    local paket       = {}
    local PlayerCount = #Players:GetPlayers()
    local MaxPlayers  = Players.MaxPlayers

    for _, obj in ipairs(PetFolder:GetChildren()) do
        local namaLower = obj.Name:lower()
        for _, namaPet in ipairs(ListNamaPet) do
            if string.find(namaLower, namaPet:lower()) then
                if not paket[namaPet] then
                    local part = obj:IsA("BasePart") and obj or obj:FindFirstChildWhichIsA("BasePart", true) or obj.PrimaryPart
                    if part then
                        local meta = PetMetadata[namaPet] or { Tier = 1 }
                        paket[namaPet] = {
                            PetName        = namaPet,
                            Tier           = meta.Tier,
                            Rarity         = meta.Rarity or "Common",
                            JobId          = game.JobId,
                            PlaceId        = game.PlaceId,
                            Position       = { X = part.CFrame.X, Y = part.CFrame.Y, Z = part.CFrame.Z },
                            Timestamp      = os.time(),
                            CurrentPlayers = PlayerCount,
                            MaxPlayers     = MaxPlayers,
                        }
                    end
                end
                break
            end
        end
    end
    return paket
end

-- ============================================================
-- MAIN ENGINE CONTROL (INTELLIGENT 2X SCAN WITH ANTI-LAG)
-- ============================================================
local function ScanDanHop()
    DaftarkanKehadiranAktif()

    local MapFolder = workspace:WaitForChild("Map", 20)
    local PetFolder = MapFolder and MapFolder:WaitForChild("WildPetSpawns", 20)

    if not PetFolder then
        HapusDataServer()
        HopServer()
        return
    end

    -- ============================================================
    -- SCAN 1: CEK DATA AWAL PAS MASUK SERVER
    -- ============================================================
    local paket = JalankanScanWorkspace(PetFolder)
    local adaPetBernilaiTinggi = false

    for _, data in pairs(paket) do
        if data.Tier and data.Tier >= 5 then adaPetBernilaiTinggi = true break end
    end

    -- PROTEKSI SEGERA JIKA SERVER PENUH (>= 6 Pemain)
    if #Players:GetPlayers() >= 6 then
        if adaPetBernilaiTinggi then
            KirimFirebase(paket)
            KirimDiscord(paket, #Players:GetPlayers(), Players.MaxPlayers, game.JobId, game.PlaceId)
            task.wait(10) -- Tetap beri celah 10 detik untuk akun utama masuk
        end
        HapusDataServer()
        HopServer()
        return
    end

    -- KIRIM LAPORAN SCAN 1 (Kondisi Awal)
    if next(paket) ~= nil then
        print("[Bot Scan 1] Mengirim kondisi awal pet ke database...")
        KirimFirebase(paket)
        KirimDiscord(paket, #Players:GetPlayers(), Players.MaxPlayers, game.JobId, game.PlaceId)
        task.wait(1.5)
        
        if adaPetBernilaiTinggi then
            print("[Bot Scan 1] Target Mythic/Super didapat! Menahan server 10 detik...")
            task.wait(10)
        end
    end

    -- ============================================================
    -- LOGIKA TUNGGU SPAWN (JIKA SEPI & TOTAL OBJECT PET < 4)
    -- ============================================================
    local totalObjekPet = HitungTotalPetDiWorkspace(PetFolder)

    if totalObjekPet < 4 then
        print("[Bot Mode Tunggu] Jumlah objek pet saat ini: " .. tostring(totalObjekPet) .. ". Menunggu spawn baru...")
        local targetPetSetelahSpawn = totalObjekPet + 1
        
        local timeout = 0
        while HitungTotalPetDiWorkspace(PetFolder) < targetPetSetelahSpawn and timeout < 120 do
            task.wait(2)
            timeout = timeout + 2
            
            -- Jika saat menunggu server mendadak penuh, langsung abort & hop!
            if #Players:GetPlayers() >= 6 then
                print("[Bot Cancel Tunggu] Server mendadak ramai, batalkan antrean.")
                HapusDataServer()
                HopServer()
                return
            end
        end

        -- ============================================================
        -- SCAN 2: SETELAH DETEKSI SPAWN OBJEK BARU BERHASIL
        -- ============================================================
        print("[Bot Scan 2] Pet baru terbit! Memperbarui data terkini...")
        task.wait(1) -- Beri waktu 1 detik agar node mesh ter-render sempurna
        
        paket = JalankanScanWorkspace(PetFolder) -- Ambil database struktur baru
        adaPetBernilaiTinggi = false
        for _, data in pairs(paket) do
            if data.Tier and data.Tier >= 5 then adaPetBernilaiTinggi = true break end
        end

        if next(paket) ~= nil then
            KirimFirebase(paket)
            KirimDiscord(paket, #Players:GetPlayers(), Players.MaxPlayers, game.JobId, game.PlaceId)
            task.wait(1.5)
            
            if adaPetBernilaiTinggi then
                print("[Bot Scan 2] Target Mythic/Super terdeteksi pasca spawn! Mengunci 10 detik...")
                task.wait(10)
            end
        end
    end

    -- ============================================================
    -- MONITOR CAMPING / SELESAI & PINDAH
    -- ============================================================
    if adaPetBernilaiTinggi then
        print("[Bot Mode Camp] Memulai pemantauan ketat target tinggi...")
        while adaPetBernilaiTinggi do
            task.wait(3)
            if #Players:GetPlayers() >= 6 then break end 
            local updatePaket = JalankanScanWorkspace(PetFolder)
            adaPetBernilaiTinggi = false
            for _, data in pairs(updatePaket) do
                if data.Tier and data.Tier >= 5 then adaPetBernilaiTinggi = true break end
            end
            if adaPetBernilaiTinggi then
                KirimFirebase(updatePaket)
            else
                print("[Bot Mode Camp] Target diambil/hilang. Selesai.")
            end
        end
    else
        task.wait(1)
    end

    HapusDataServer()
    HopServer()
end

