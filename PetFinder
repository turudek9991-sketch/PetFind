local function FormatAngka(n)
    local s, result, count = tostring(math.floor(n)), "", 0
    for i = #s, 1, -1 do
        if count > 0 and count % 3 == 0 then result = "," .. result end
        result = s:sub(i, i) .. result
        count  = count + 1
    end
    return result
end

-- ============================================================
-- UNIVERSAL HTTP WRAPPER DENGAN RETRY
-- ============================================================
local function SafeHttp(options)
    for percobaan = 1, 3 do
        local ok, res = pcall(HttpRequest, options)
        if ok then
            print("[HTTP OK] " .. options.Method .. " " .. options.Url)
            return true
        else
            warn("[HTTP Gagal] Percobaan " .. percobaan .. "/3 — " .. tostring(res))
            task.wait(2)
        end
    end
    warn("[HTTP] Menyerah setelah 3x: " .. options.Url)
    return false
end

