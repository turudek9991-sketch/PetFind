-- FIREBASE API MECHANICS
-- ============================================================
local KLAIM_TTL = 30

local function KlaimServer(targetJobId)
    SafeHttp({
        Url     = FirebaseURL .. "BotClaims/" .. BOT_ID .. ".json",
        Method  = "PUT",
        Headers = { ["Content-Type"] = "application/json" },
        Body    = HttpService:JSONEncode({ TargetJobId = targetJobId, Timestamp = os.time() }),
    })
end

local function HapusKlaim()
    pcall(HttpRequest, { Url = FirebaseURL .. "BotClaims/" .. BOT_ID .. ".json", Method = "DELETE" })
end

local function AmbilServerDiklaim()
    local diklaim = {}
    local ok, res = pcall(HttpRequest, { Url = FirebaseURL .. "BotClaims.json", Method = "GET" })
    if not ok or not res or not res.Body then return diklaim end
    local okD, data = pcall(function() return HttpService:JSONDecode(res.Body) end)
    if not okD or type(data) ~= "table" then return diklaim end
    local now = os.time()
    for botId, info in pairs(data) do
        if botId ~= BOT_ID and type(info) == "table"
            and type(info.TargetJobId) == "string"
            and type(info.Timestamp) == "number"
            and (now - info.Timestamp) < KLAIM_TTL then
            diklaim[info.TargetJobId] = true
        end
    end
    return diklaim
end

